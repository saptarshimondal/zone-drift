{
  "manifest_version": 3,
  "name": "ZonneDrift",
  "version": "0.0.1",
  "description": "A boilerplate that works across modern browsers.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "js/background/background.js",
    "scripts": ["js/background/background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "zonedrift@example.com",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon-192.png",
    "32": "icons/icon-192.png",
    "48": "icons/icon-192.png",
    "128": "icons/icon-512.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-192.png",
      "32": "icons/icon-192.png",
      "48": "icons/icon-192.png",
      "128": "icons/icon-512.png"
    }
  }
}